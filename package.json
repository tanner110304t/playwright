{
  "name": "environmental-sensor-dashboard",
  "version": "1.0.0",
  "description": "A beginner-friendly QET project with an Express API, frontend dashboard, Jest API tests, and Playwright e2e tests",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --testPathPattern=tests/",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "@playwright/test": "^1.44.0"
  }
}